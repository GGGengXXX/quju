# .env.example — 复制为 .env（已 gitignore），填入真实值。真实值来源见 docs/secrets-and-config.md
# 切勿提交 .env / 真实密钥。

# ---- 后端服务 ----
SERVER_PORT=8080
# 开发/部署库 = docker 容器 quju-mysql(mysql:8.4)；宿主端口 13306，容器内为 quju-mysql:3306
DB_URL=jdbc:mysql://127.0.0.1:13306/quju?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8
DB_USERNAME=quju
DB_PASSWORD=        # 见服务器 /root/quju/mysql.env 的 MYSQL_PASSWORD（勿提交）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_KEY_PREFIX=
JWT_SECRET=

# ---- 阿里云 OSS（对象存储：头像/活动图/群文件/相册/总结图）----
OSS_ACCESS_KEY_ID=        # 见 AccessKey.csv，勿提交
OSS_ACCESS_KEY_SECRET=    # 见 AccessKey.csv，勿提交
OSS_BUCKET=se-resource-bucket
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

# ---- 前端 ----
VITE_PORT=5173
VITE_API_BASE=http://127.0.0.1:8080/v1
VITE_AMAP_KEY=           # 高德地图 key，见 高德地图-api-key.txt（勿提交）

# ---- 部署（仅服务器 deploy/.env 用；勿入库）----
DEPLOY_HOST=1.92.124.5
# DEPLOY_PASSWORD=       # 见 HuaweiCloud.txt，勿提交；建议改用 SSH key

# ---- AI（DeepSeek，OpenAI 兼容）----
AI_BASE_URL=https://hk.n1n.ai/v1
AI_MODEL=deepseek-v3.2
AI_API_KEY=              # 见 deepseek-api-key.txt（勿提交）

# ---- 其它第三方（待提供）----
SMTP_URL=                # 账号激活邮件  <<TODO>>
SMTP_PASSWORD=           # <<TODO>>
