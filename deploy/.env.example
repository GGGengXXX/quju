# deploy/.env.example — 复制为 deploy/.env（服务器本地，已 gitignore，勿提交）
# 部署时 docker-compose 读取。真实值来源见 docs/secrets-and-config.md

# 数据库（app 账号 quju；密码取自服务器 /root/quju/mysql.env 的 MYSQL_PASSWORD）
DB_USERNAME=quju
DB_PASSWORD=

# JWT 签名密钥（生产环境随机生成，例如 openssl rand -base64 48）
JWT_SECRET=

# 阿里云 OSS（值见 AccessKey.csv）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=se-resource-bucket
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

# AI（DeepSeek，OpenAI 兼容）
AI_BASE_URL=https://hk.n1n.ai/v1
AI_MODEL=deepseek-v3.2
AI_API_KEY=

# 邮件 SMTP（网易 163，账号激活/密码重置）
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=tluvx0806@163.com
SMTP_PASSWORD=
SMTP_SSL=true
MAIL_FROM=tluvx0806@163.com

# 高德地图 Key（前端构建期注入，值见 高德地图-api-key.txt）
# compose 通过 build.args 传给 frontend/Dockerfile 的 ARG VITE_AMAP_KEY
VITE_AMAP_KEY=
